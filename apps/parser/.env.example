# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=peraturan_db
DB_USER=postgres
DB_PASSWORD=postgres

# Application Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Scraping Configuration
SCRAPER_BASE_URL=https://peraturan.go.id
SCRAPER_REQUEST_DELAY=1
SCRAPER_TIMEOUT=30

# PDF Parser Configuration
PDF_PARSER_MAX_PAGES=1000
PDF_PARSER_EXTRACT_IMAGES=false

# GLM AI Configuration (for AI-based parsing)
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4.6v
GLM_MAX_TOKENS=4096
GLM_TEMPERATURE=0.1
GLM_TIMEOUT=120
